<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

    <addon id="plugin.video.jodete_tebas" name="Jodete Tebas" version="1.5.3" provider-name="Gunter25">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="addon.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Canales y Agenda de fútbol vía Acestream</summary>
            <description>
                Reproduce canales Acestream y consulta la agenda de partidos directamente en Kodi.
                Requiere Ace Stream Engine instalado en tu dispositivo (PC/Linux) o la app Acestream para Android.
                Este addon solo muestra y organiza enlaces disponibles públicamente en internet.
                No aloja, distribuye ni es responsable del contenido enlazado.
                El uso del addon es responsabilidad del usuario.
            </description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>

    <addon id="repository.jodete_tebas" name="Jodete Tebas Repo" version="1.0.0" provider-name="Gunter25">
        <extension point="xbmc.addon.repository" name="Jodete Tebas Repo">
            <dir>
                <info compressed="false">https://jlatorreaguilar.github.io/jodeteTebas/addons.xml</info>
                <checksum>https://jlatorreaguilar.github.io/jodeteTebas/addons.xml.md5</checksum>
                <datadir zip="true">https://jlatorreaguilar.github.io/jodeteTebas/repo/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Repositorio oficial de Jodete Tebas</summary>
            <description>
                Repositorio oficial del addon Jodete Tebas creado y mantenido por Gunter25.
                Canales y Agenda de fútbol vía Acestream.
            </description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>

</addons>
